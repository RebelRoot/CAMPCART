# Cloudinary Configuration
# Get these from your Cloudinary Dashboard: https://cloudinary.com/console
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# Backend API URL
VITE_BACKEND_URL=https://api.campcart.online/api

# Cloudflare Turnstile (production sitekey)
# Get from: https://dash.cloudflare.com/?to=/:account/turnstile
VITE_TURNSTILE_SITEKEY=

# Vite dev server allowed hosts (comma-separated)
VITE_ALLOWED_HOSTS=campcart.online
